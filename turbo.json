{
	"$schema": "https://turbo.build/schema.json",
	"globalEnv": [
		"ACCESS_TOKEN_SECRET",
		"REFRESH_TOKEN_SECRET",
		"GMAIL_APP_PASSWORD",
		"DATABASE_URL",
		"DIRECT_URL"
	],
	"tasks": {
		"build": {
			"dependsOn": ["^build"],
			"outputs": ["dist/**", ".next/**"]
		},

		"dev": {
			"cache": false,
			"persistent": true
		}
	}
}
