{
	"compilerOptions": {
		"outDir": "./dist",
		"rootDir": "./src",
		"module": "NodeNext",
		"moduleResolution": "NodeNext",
		"target": "ES2022",
		"declaration": true,
		"declarationMap": true,
		"allowSyntheticDefaultImports": true,
		"sourceMap": true,
		"strict": true,
		"skipLibCheck": true,
    "types": ["node"],
		"esModuleInterop": true
	},

	"include": ["src"]
}
