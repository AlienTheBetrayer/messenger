{
  "extends": "../../tsconfig.base.json",
	"compilerOptions": {
		"outDir": "./dist",
		"rootDir": "./src",
		"module": "NodeNext",
		"moduleResolution": "NodeNext",
		"target": "ES2022",
		"declaration": true,
		"declarationMap": true,
		"resolveJsonModule": true,
		"allowSyntheticDefaultImports": true,
		"sourceMap": true,
		"strict": true,
		"composite": true,
		"skipLibCheck": true,
		"types": ["node"],
		"esModuleInterop": true
	},

	"include": ["src/**/*", "src/**/*.json"]
}
