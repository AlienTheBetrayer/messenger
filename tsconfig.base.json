{
	"compilerOptions": {
		"target": "esnext",
		"module": "nodenext",
		"moduleResolution": "nodenext",
		"lib": ["ES2022"],
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true,
		"resolveJsonModule": true,
		"isolatedModules": true,
		"declaration": true,
		"declarationMap": true,
		"sourceMap": true
	},
	"exclude": ["node_modules"],
	"references": [
		{ "path": "./apps/api" },
		{ "path": "./apps/web" },
		{ "path": "./packages/shared" }
	]
}
