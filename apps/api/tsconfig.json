{
	"compilerOptions": {
		"module": "NodeNext",
		"moduleResolution": "NodeNext",
		"target": "ES2023",
		"strict": true,
		"skipLibCheck": true,
		"esModuleInterop": true,
		"allowSyntheticDefaultImports": true,
		"experimentalDecorators": true,
		"emitDecoratorMetadata": true,
		"sourceMap": true,
		"incremental": false,
		"rootDir": "./src",
		"outDir": "./dist",
    "types": ["node", "jest"]
	},
  
	"include": ["src"],
	"exclude": ["node_modules", "dist"]
}
