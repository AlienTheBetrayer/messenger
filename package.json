{
  "name": "gravity",
  "version": "0.0.0",
  "private": true,
  "packageManager": "npm@10.9.2",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "dev:web": "turbo run dev --filter=web",
    "dev:api": "turbo run dev --filter=api",
    "build:web": "turbo run build --filter=web",
    "build:api": "turbo run build --filter=api"
  },
  "devDependencies": {
    "turbo": "^2"
  }
}
